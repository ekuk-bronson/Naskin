{
  "expo": {
    "name": "FreeSkinApp",
    "slug": "FreeSkinApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freeskinapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.freeskin.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FreeSkin использует камеру для фотографирования родинок.",
        "NSPhotoLibraryUsageDescription": "FreeSkin сохраняет и загружает фото родинок из галереи.",
        "NSUserNotificationsUsageDescription": "FreeSkin отправляет напоминания о повторной проверке родинок."
      }
    },
    "android": {
      "package": "com.freeskin.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F6F3",
          "dark": {
            "backgroundColor": "#1C1A18"
          }
        }
      ],
      "expo-sqlite",
      "react-native-fast-tflite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f05fa081-ce8f-46e1-ae34-ac81166d6518"
      }
    }
  }
}
