# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth Client IDs for expo-auth-session
# ─────────────────────────────────────────────────────────────────────────────
#
# SETUP INSTRUCTIONS:
#
# 1. Create a project at https://console.cloud.google.com
#
# 2. Enable "Google Sign-In" API:
#    APIs & Services → Library → "Google People API" → Enable
#
# 3. Create OAuth credentials (APIs & Services → Credentials → Create Credentials):
#
#    a) "Web application":
#       - Authorized redirect URIs: https://auth.expo.io/@YOUR_EXPO_USERNAME/FreeSkinApp
#       - This gives you the "Expo Client ID" (works in Expo Go)
#
#    b) "Android":
#       - Package name: com.yourcompany.FreeSkinApp (from app.json → android.package)
#       - SHA-1: run `npx expo credentials:manager` to get it
#
#    c) "iOS":
#       - Bundle ID: com.yourcompany.FreeSkinApp (from app.json → ios.bundleIdentifier)
#
# 4. Copy this file to .env and fill in the values:
#    cp .env.example .env
#
# 5. Restart Metro: npx expo start --clear
# ─────────────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=REPLACE_WITH_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=REPLACE_WITH_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=REPLACE_WITH_ANDROID_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=REPLACE_WITH_IOS_CLIENT_ID.apps.googleusercontent.com
